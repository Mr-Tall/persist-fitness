{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:status": "prisma migrate status",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:check-migration": "node scripts/check-prisma-migration.mjs",
    "db:validate": "npm run prisma:validate",
    "db:migrate:status": "npm run prisma:status",
    "db:migrate:deploy": "npm run prisma:deploy",
    "validate": "npm run prisma:generate && npm run prisma:validate && npm run lint && npx tsc --noEmit && npm run test && npm run build",
    "release:check": "npm run validate",
    "release:smoke": "node scripts/smoke-production.mjs",
    "native:sync:ios:dev": "cross-env CAPACITOR_BUILD_MODE=development cap sync ios",
    "native:sync:ios:production": "cross-env CAPACITOR_BUILD_MODE=production cap sync ios",
    "native:open:ios": "cap open ios",
    "native:run:ios": "cross-env CAPACITOR_BUILD_MODE=development cap run ios"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.67.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.11",
    "next-auth": "^5.0.0-beta.31",
    "posthog-js": "^1.406.2",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
