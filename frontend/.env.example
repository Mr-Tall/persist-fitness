# Runtime application database connection. Use the pooled application URL in hosted environments.
DATABASE_URL=

# Auth.js session encryption secret. Generate a unique value for each hosted environment.
AUTH_SECRET=

# Google OAuth application credentials for the current environment.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Canonical application URL. AUTH_URL is preferred; NEXTAUTH_URL is accepted as a fallback.
AUTH_URL=
# NEXTAUTH_URL=

# Direct PostgreSQL connection used only by Prisma CLI and migration operations.
# Configure this separately for Vercel Preview and Production environments.
DIRECT_URL=
